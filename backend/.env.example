NODE_ENV=development
PORT=3000
CORS_ALLOWED_ORIGINS="http://localhost:3001"
DATABASE_URL="postgresql://postgres:postgres@localhost:54329/vervet_network?schema=public"
ADMIN_API_TOKEN="change-me-admin-token"
WEBHOOK_SIGNING_MASTER_SECRET="change-me-webhook-master-secret"
WEBHOOK_ALLOW_PRIVATE_TARGETS=true
WEBHOOK_DELIVERY_PROCESSOR_ENABLED=true
WEBHOOK_DELIVERY_PROCESSOR_INTERVAL_MS=30000
WEBHOOK_DELIVERY_PROCESSOR_BATCH_SIZE=50
WEBHOOK_DELIVERY_PROCESSING_STALE_MS=60000
ATTESTATION_REQUEST_MAX_AGE_MS=300000
ATTESTATION_REQUEST_NONCE_TTL_MS=600000
PARTNER_API_CREDENTIAL_LAST_USED_MIN_INTERVAL_MS=60000
PARTNER_DASHBOARD_SESSION_TTL_MS=43200000
PARTNER_DASHBOARD_SESSION_LAST_USED_MIN_INTERVAL_MS=60000
RESOLUTION_REQUEST_RETENTION_MS=2592000000
RESOLUTION_LOOKUP_RATE_LIMIT_WINDOW_MS=60000
RESOLUTION_LOOKUP_RATE_LIMIT_MAX_REQUESTS=120
RESOLUTION_LOOKUP_ENUMERATION_WINDOW_MS=300000
RESOLUTION_LOOKUP_ENUMERATION_MAX_IDENTIFIERS=40
